// Let an active local session start/stop torando-gui.service without a password
// prompt, while still requiring admin auth from inactive/remote sessions.
polkit.addRule(function (action, subject) {
  if (
    action.id === "org.freedesktop.systemd1.manage-units" &&
    action.lookup("unit") === "torando-gui.service"
  ) {
    if (subject.active && subject.local) {
      return polkit.Result.YES;
    }
    return polkit.Result.AUTH_ADMIN;
  }
});
